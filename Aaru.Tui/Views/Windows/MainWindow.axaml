<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windows="clr-namespace:Aaru.Tui.ViewModels.Windows"
        xmlns:mvvm="http://prismlibrary.com/"
        x:Class="Aaru.Tui.Views.Windows.MainWindow"
        RequestedThemeVariant="Dark"
        x:DataType="windows:MainWindowViewModel"
        mvvm:ViewModelLocator.AutoWireViewModel="True"
        Title="Aaru">
    <Design.DataContext>
        <windows:MainWindowViewModel />
    </Design.DataContext>
    <!-- Prism Region for page navigation and back/forward journaling -->
    <ContentControl mvvm:RegionManager.RegionName="ContentRegion" />
</Window>